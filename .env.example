PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/wanderon-auth
ACCESS_TOKEN_SECRET=replace-with-a-long-random-access-token-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-a-long-random-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=7d
ACCESS_COOKIE_NAME=wanderon_access_token
REFRESH_COOKIE_NAME=wanderon_refresh_token
CLIENT_URL=http://localhost:5173
NODE_ENV=development

